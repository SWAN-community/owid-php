{
    "name": "swan-community/owid",
    "description": "Open Web Id (OWID) implementation in PHP. Create, sign, serialize, and verify cryptographically auditable identifiers.",
    "type": "library",
    "license": "Apache-2.0",
    "version": "0.1.0",
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SwanCommunity\\Owid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SwanCommunity\\Owid\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
